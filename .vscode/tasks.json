{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Setup Development Environment",
      "type": "shell",
      "command": "./setup_dev_env.sh",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "echo": true
      },
      "group": {
        "kind": "build"
      }
    },
    {
      "label": "Run All Checks",
      "type": "shell",
      "command": "./run_checks.sh",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "echo": true
      },
      "group": {
        "kind": "build"
      }
    }
  ]
}
