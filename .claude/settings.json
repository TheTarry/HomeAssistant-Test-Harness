{
  "permissions": {
    "allow": [
      "Bash(pre-commit run:*)",
      "Bash(uv run:*)",
      "Bash(./run_checks.sh)",
      "Bash(bash run_checks.sh)",
      "WebFetch(domain:developers.home-assistant.io)",
      "WebFetch(domain:www.home-assistant.io)",
      "WebFetch(domain:community.home-assistant.io)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "WebFetch",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/allow-web-fetch-trusted-sources.sh"
          }
        ]
      }
    ]
  }
}
